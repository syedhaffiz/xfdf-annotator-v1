{
  "compilerOptions": {
    /* ── Language & Environment ─────────────────────────────────── */
    "target": "ES2020",            // Fabric.js and pdfjs-dist target modern browsers
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "useDefineForClassFields": true,

    /* ── Module System ──────────────────────────────────────────── */
    "module": "ESNext",
    "moduleResolution": "bundler", // Works with Vite's bundler module resolution
    "resolveJsonModule": true,

    /* ── Emit ───────────────────────────────────────────────────── */
    "declaration": true,           // Generate .d.ts files for consumers
    "declarationDir": "dist",
    "emitDeclarationOnly": true,   // Vite handles the actual JS bundling
    "sourceMap": true,
    "outDir": "dist",

    /* ── Interop ────────────────────────────────────────────────── */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,       // Required for Vite's fast compilation

    /* ── Strictness ─────────────────────────────────────────────── */
    "strict": true,                // Enable all strict type checks
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,

    /* ── Skip lib check to avoid noise from third-party .d.ts ─── */
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
