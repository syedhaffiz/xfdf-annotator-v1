{
  "name": "xfdf-annotator",
  "version": "0.1.0",
  "description": "Lightweight browser-based PDF and image annotation library using the XFDF standard (ISO 19444-1)",
  "author": "",
  "license": "MIT",
  "keywords": [
    "pdf",
    "annotation",
    "xfdf",
    "canvas",
    "fabric",
    "pdfjs",
    "image-annotation",
    "pdf-viewer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/syedhaffiz/xfdf-annotator-v1.git"
  },
  "type": "module",
  "main": "./dist/xfdf-annotator.cjs",
  "module": "./dist/xfdf-annotator.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/xfdf-annotator.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/xfdf-annotator.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "fabric": "^7.3.1",
    "pdfjs-dist": "^5.6.205"
  },
  "devDependencies": {
    "fabric": "^7.3.1",
    "pdfjs-dist": "^5.6.205",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4"
  }
}
