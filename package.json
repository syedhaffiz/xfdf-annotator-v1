{
  "name": "xfdf-annotator",
  "version": "0.1.0",
  "description": "Lightweight browser-based PDF and image annotation library using the XFDF standard (ISO 19444-1)",
  "author": "",
  "license": "MIT",
  "keywords": [
    "pdf",
    "annotation",
    "xfdf",
    "canvas",
    "fabric",
    "pdfjs",
    "image-annotation",
    "pdf-viewer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/syedhaffiz/xfdf-annotator-v1.git"
  },

  "type": "module",

  "main": "./dist/xfdf-annotator.cjs",
  "module": "./dist/xfdf-annotator.js",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/xfdf-annotator.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/xfdf-annotator.cjs"
      }
    }
  },

  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],

  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },

  "peerDependencies": {
    "fabric": "^5.3.0",
    "pdfjs-dist": "^3.11.174"
  },

  "devDependencies": {
    "@types/fabric": "^5.3.0",
    "fabric": "^5.3.0",
    "pdfjs-dist": "^3.11.174",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.0"
  }
}
